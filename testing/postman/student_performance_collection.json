          }
        }
      ]
    },
    {
      "name": "Filter by Gender",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/students?gender=Male",
          "host": ["{{base_url}}"],
          "path": ["students"],
          "query": [
            {
              "key": "gender",
              "value": "Male"
            }
          ]
        },
        "description": "Get students filtered by gender"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"All students are Male\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.data.forEach(function(student) {",
              "        pm.expect(student.Gender).to.eql('Male');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Filter by Test Preparation",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/students?test_preparation=Completed",
          "host": ["{{base_url}}"],
          "path": ["students"],
          "query": [
            {
              "key": "test_preparation",
              "value": "Completed"
            }
          ]
        },
        "description": "Get students filtered by test preparation"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"All students completed test preparation\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.data.forEach(function(student) {",
              "        pm.expect(student.TestPreparationCourse).to.eql('Completed');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Performance Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/performance-summary",
          "host": ["{{base_url}}"],
          "path": ["performance-summary"]
        },
        "description": "Get comprehensive performance summary"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has overall stats\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('overall');",
              "    pm.expect(jsonData.overall).to.have.property('pass_rate');",
              "});",
              "",
              "pm.test(\"Response has gender stats\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('by_gender');",
              "});",
              "",
              "pm.test(\"Response has test preparation stats\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('by_test_preparation');",
              "});",
              "",
              "pm.test(\"Pass rate is between 0 and 100\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.overall.pass_rate).to.be.at.least(0);",
              "    pm.expect(jsonData.overall.pass_rate).to.be.at.most(100);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Subject Statistics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/subject-stats",
          "host": ["{{base_url}}"],
          "path": ["subject-stats"]
        },
        "description": "Get statistics by subject"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has subject stats\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('MathScore');",
              "    pm.expect(jsonData).to.have.property('ReadingScore');",
              "    pm.expect(jsonData).to.have.property('WritingScore');",
              "});",
              "",
              "pm.test(\"Each subject has required stats\", function () {",
              "    var jsonData = pm.response.json();",
              "    ['MathScore', 'ReadingScore', 'WritingScore'].forEach(function(subject) {",
              "        pm.expect(jsonData[subject]).to.have.property('mean');",
              "        pm.expect(jsonData[subject]).to.have.property('std');",
              "        pm.expect(jsonData[subject]).to.have.property('min');",
              "        pm.expect(jsonData[subject]).to.have.property('max');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Education Statistics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/education-stats",
          "host": ["{{base_url}}"],
          "path": ["education-stats"]
        },
        "description": "Get statistics by parental education level"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains education data\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(Object.keys(jsonData).length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Each education level has required fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    Object.keys(jsonData).forEach(function(edu) {",
              "        pm.expect(jsonData[edu]).to.have.property('count');",
              "        pm.expect(jsonData[edu]).to.have.property('average_overall');",
              "        pm.expect(jsonData[edu]).to.have.property('pass_rate');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
