    {
      "name": "Negative Test - Missing Fields Validation",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/students",
          "host": ["{{base_url}}"],
          "path": ["students"]
        },
        "description": "Validate response schema and required fields"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains all required fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.data.length > 0) {",
              "        var requiredFields = ['StudentID', 'Gender', 'ParentalEducation', 'MathScore', 'ReadingScore', 'WritingScore', 'AverageScore'];",
              "        requiredFields.forEach(function(field) {",
